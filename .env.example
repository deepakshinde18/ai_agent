# Copy to backend/.env and fill in real values. Never commit the real .env file.

# --- Agent's own Postgres (sessions, LangGraph checkpoints, auth, audit log) ---
# Async URL used by the running app (asyncpg driver).
AGENT_DATABASE_URL=postgresql+asyncpg://agent_user:changeme@localhost:5432/insight_agent
# Sync URL used only by Alembic migrations (psycopg driver).
AGENT_DATABASE_URL_SYNC=postgresql+psycopg://agent_user:changeme@localhost:5432/insight_agent

# --- Business/target Postgres (separate instance, read-only role recommended) ---
TARGET_DATABASE_URL=postgresql+asyncpg://readonly_user:changeme@localhost:5433/business_data
TARGET_QUERY_TIMEOUT_SECONDS=15

# --- Azure OpenAI (accessed via the OpenAI-SDK-compatible /openai/v1 surface) ---
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=changeme
# These are Azure *deployment names*, not base model names.
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- Chroma (local persistent vector store) ---
CHROMA_PERSIST_DIR=./.chroma_data
INTENT_CONFIDENCE_THRESHOLD=0.75

# --- JWT auth ---
JWT_SECRET_KEY=changeme-generate-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Presidio ---
PRESIDIO_SPACY_MODEL=en_core_web_lg

# --- Misc ---
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=["http://localhost:5173"]
